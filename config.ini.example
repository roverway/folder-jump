; FolderJump configuration template
; Copy this file to config.ini and adjust values as needed.

[general]
; Hotkey in AHK format: ^=Ctrl, !=Alt, +=Shift, #=Win
hotkey=^g
; Path refresh interval in milliseconds
poll_interval=500
; Debounce interval in milliseconds
debounce_ms=300
; Auto close timeout for the selector UI in seconds
auto_close_timeout=10
; UI theme: dark or light
theme=dark

[adapters]
enable_explorer=1
enable_totalcmd=1
enable_dopus=1

[ui]
show_source_label=1
max_items=12
sort_by=recent
position=below_window

[log]
log_level=INFO
log_max_size=1048576
log_max_files=3
