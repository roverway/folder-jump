; FolderJump 配置模板
; 复制为 config.ini 后按需修改。

[general]
; 热键，AHK 格式：^=Ctrl, !=Alt, +=Shift, #=Win
hotkey=^g
; 路径刷新间隔，单位毫秒
poll_interval=500
; 热键防抖间隔，单位毫秒
debounce_ms=300
; 选择面板自动关闭时间，单位秒
auto_close_timeout=10
; 主题：dark 或 light
theme=dark

[adapters]
enable_explorer=1
enable_totalcmd=1
enable_dopus=1

[ui]
show_source_label=1
max_items=12
sort_by=recent
position=below_window

[log]
log_level=INFO
log_max_size=1048576
log_max_files=3
